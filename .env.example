TELEGRAM_BOT_TOKEN=123456789:replace_me
# Numeric Telegram IDs, comma separated. Obtain yours from @userinfobot.
TELEGRAM_ALLOWED_USER_IDS=123456789
# Use a separate, ordinary X account. Copy these two cookies from an active
# x.com browser session. They grant account access and must be treated as secrets.
X_AUTH_TOKEN=replace_me
X_CT0=replace_me
X_MAX_REPLIES=5000
X_ACCOUNT_DB=/tmp/accounts.db
TWS_TELEMETRY=0
TWS_HTTP_BACKEND=curl
